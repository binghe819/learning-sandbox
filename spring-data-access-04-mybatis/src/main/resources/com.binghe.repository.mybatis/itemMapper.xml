<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.binghe.repository.mybatis.ItemMapper">

    <!--
        useGeneratedKeys="true"
          JDBC의 getGeneratedKeys()를 사용해 DB가 AUTO_INCREMENT로 생성한 PK를 가져온다.

        keyProperty="id"
          가져온 PK 값을 파라미터 객체(Item)의 id 필드에 세팅한다.
          즉, save() 호출 후 item.getId()를 통해 생성된 id를 읽을 수 있다.

        주의: MyBatis <insert>의 반환 타입은 항상 int(영향받은 행 수)이다.
             생성된 키는 반환값이 아니라 keyProperty로 지정한 필드에 주입된다.
             따라서 Mapper 인터페이스의 save() 반환값으로 id를 직접 받을 수 없고,
             Repository 계층에서 item.getId()로 꺼내야 한다.
             (자세한 내용은 MyBatisItemRepository.save() 주석 참고)
    -->
    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        insert into item (item_name, price, quantity)
        values (#{itemName}, #{price}, #{quantity})
    </insert>

    <update id="update">
        update item
        set item_name=#{updateParam.itemName},
            price=#{updateParam.price},
            quantity=#{updateParam.quantity}
        where id=#{id}
    </update>

    <select id="findById" resultType="Item">
        select id, item_name, price, quantity
        from item
        where id = #{id}
    </select>

    <!--
        <where> 태그: 조건이 하나라도 있으면 자동으로 WHERE를 붙이고,
                     AND/OR로 시작하는 조건이 있으면 앞의 AND/OR를 제거한다.
                     JdbcTemplate V1/V2에서 andFlag로 수동 관리하던 로직을 선언적으로 대체한다.

        <if> 태그: 조건이 참일 때만 해당 SQL 조각을 포함시킨다.
    -->
    <select id="findAll" resultType="Item">
        select id, item_name, price, quantity
        from item
        <where>
            <if test="itemName != null and itemName != ''">
                and item_name like concat('%', #{itemName}, '%')
            </if>
            <if test="maxPrice != null">
                and price &lt;= #{maxPrice}
            </if>
        </where>
    </select>

</mapper>
